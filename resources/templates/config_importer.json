{
  "app": {
    "sheet_name": "dataset",
    "validation": {
      "skip_issuetypes": [
        "comment",
        "note",
        "skip"
      ]
    },
    "version": "2.0.0"
  },
  "jira": {
    "connection": {
      "auth": {
        "api_token": "${ENV:JIRA_API_TOKEN}",
        "email": "${ENV:JIRA_EMAIL}",
        "mode": "basic"
      },
      "cloud_id": "",
      "oauth": {
        "client_id": "${ENV:JIRA_OAUTH_CLIENT_ID}",
        "client_secret": "${ENV:JIRA_OAUTH_CLIENT_SECRET}",
        "refresh_token": "${ENV:JIRA_OAUTH_REFRESH_TOKEN}"
      },
      "site_address": "https://xyz.atlassian.net"
    },
    "project": {
      "id": 0,
      "key": "JITTP2"
    },
    "validation": {
      "components": [
        "design",
        "development",
        "production",
        "quality assurance",
        "quality control",
        "devops",
        "sysops",
        ""
      ],
      "issuetypes": [
          { "name": "initiative", "level": 1 },
          { "name": "epic", "level": 2 },
          { "name": "story", "level": 3 },
          { "name": "task", "level": 3 },
          { "name": "bug", "level": 3 },
          { "name": "sub-task", "level": 4 }
        ],
      "priorities": [
        "medium",
        "highest",
        "high",
        "low",
        "lowest"
      ]
    }
  },
  "metadata": {
    "description": "Jira Importer Configuration",
    "last_updated": "2025-08-29",
    "version": 5
  }
