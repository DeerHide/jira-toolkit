{
  "app": {
    "import": {
      "auto_open_page": false
    }
  },
  "jira": {
    "cloud": {
      "estimate": {
        "multiply_by_60": false
      }
    },
    "connection": {
      "site_address": "https://xyz.atlassian.net"
    },
    "issuetypes": [
      { "name": "Initiative", "level": 1 },
      { "name": "Epic", "level": 2 },
      { "name": "Story", "level": 3 },
      { "name": "Task", "level": 3 },
      { "name": "Bug", "level": 3 },
      { "name": "Sub-Task", "level": 4 }
    ],
    "priorities": [
      "Highest",
      "High",
      "Medium",
      "Low",
      "Lowest"
    ],
    "project": {
      "key": "JITTP2"
    }
  },
  "metadata": {
    "version": 7
  },
  "output": {
    "estimate": {
      "unit": "seconds"
    }
  },
  "validation": {
    "estimate": {
      "accept_integers_as": "seconds",
      "fields": [
        "estimate",
        "origest"
      ]
    },
    "fixers": {
      "disabled": []
    },
    "skip_issuetypes": [
      "comment",
      "note",
      "skip"
    ],
    "skip_rowtype": true
  }
}
