{
  "directories": {
    "app_input": "jira_importer",
    "app_output": "jira importer",
    "build": "build",
    "dist": "dist",
    "temp": "build/temp",
    "source": "src/jira_importer",
    "resources": "rsc"
  },
  "files": {
    "requirements": "rsc/requirements.txt",
    "icon": "build/icons/deerhide_default.ico",
    "license": "LICENSE",
    "readme": "README.md",
    "version": "build/version/VSVersionInfo"
  },
  "pyinstaller": {
    "console": true,
    "name": "jira_importer",
    "add_data": [
      "deerhide_default.ico;.",
      "VSVersionInfo;."
    ],
    "options": {
      "icon": "deerhide_default.ico",
      "workpath": "pyinstaller_work",
      "specpath": ".",
      "paths": "src",
      "version_file": "VSVersionInfo"
    }
  },
  "code_signing": {
    "enabled": false,
    "certificate": "../../Certificates/deerhide_win_shipping.cert",
    "signtool": "../../../../Apps/Windows Kits/10/App Certification Kit/signtool.exe",
    "timestamp_server": "http://timestamp.digicert.com",
    "digest_algorithm": "SHA256"
  },
  "build_options": {
    "clean_dist": true,
    "clean_temp": false,
    "check_dependencies": false,
    "install_requirements": false,
    "copy_documentation": false,
    "build_version_file": true
  },
  "dependencies": {
    "required": ["PyInstaller", "pandas"],
    "optional": []
  },
  "output_control": {
    "verbose": true,
    "show_progress": true,
    "show_warnings": true,
    "show_debug_info": true,
    "show_timestamps": true
  }
}
