{
  "app": {
    "artifacts": {
      "delete_enabled": false
    },
    "import": {
      "auto_open_page": false
    },
    "logging": {
      "console_output": true,
      "log_level": "INFO",
      "max_log_files": 5,
      "max_log_size_mb": 10
    },
    "version": "2.0.0"
  },
  "documentation": {
    "active_fields": [
      "jira.connection.site_address - Your Jira instance URL",
      "jira.connection.auth.mode - basic | oauth",
      "jira.connection.auth.email - Atlassian account email (env-ready)",
      "jira.connection.auth.api_token - Atlassian API token (env-ready)",
      "jira.project.key - Your Jira project key",
      "jira.issuetypes - Issue types with hierarchy levels",
      "jira.priorities - Valid priority levels",
      "validation.fixers.disabled - Auto-fixers to disable",
      "jira.cloud.estimate.multiply_by_60 - Jira Cloud estimate compatibility",
      "output.estimate.unit - Output estimate unit (seconds/minutes)",
      "validation.skip_rowtype - Skip row type validation",
      "validation.skip_issuetypes - Skip specific issue types"
    ],
    "description": "Complete Jira Importer Toolkit Configuration File - Unified Structure",
    "examples": {
      "custom_validation": "Modify jira.priorities array",
      "disable_auto_fix": "Set validation.fixers.disabled array",
      "issue_type_hierarchy": "Configure jira.issuetypes with name and level",
      "jira_cloud_compatibility": "Set jira.cloud.estimate.multiply_by_60 to true"
    },
    "notes": [
      "Copy this file to your project directory and update the values above",
      "Use -c flag to specify custom config: jira-importer.exe data.xlsx -c config.json",
      "All validation rules are now under 'validation.*' section (single source of truth)",
      "Issue types and priorities are configured under 'jira.*' section",
      "Issue types and priorities are case-sensitive and must match Jira exactly",
      "Jira Cloud users may need jira.cloud.estimate.multiply_by_60: true",
      "This configuration eliminates duplications and provides clear structure",
      "Legacy 'app.validation.*' paths are no longer supported"
    ],
    "usage": {
      "app": "Application behavior and logging settings",
      "jira": "Jira-specific connection and project settings",
      "metadata": "Configuration file information and versioning",
      "output": "Output format and unit settings",
      "validation": "All validation rules and issue type definitions"
    }
  },
  "jira": {
    "cloud": {
      "estimate": {
        "multiply_by_60": false
      }
    },
    "connection": {
      "auth": {
        "api_token": "${ENV:JIRA_API_TOKEN}",
        "email": "${ENV:JIRA_EMAIL}",
        "mode": "basic"
      },
      "site_address": "https://your-instance.atlassian.net"
    },
    "issuetypes": [
        { "name": "Initiative", "level": 1 },
        { "name": "Epic", "level": 2 },
        { "name": "Story", "level": 3 },
        { "name": "Task", "level": 3 },
        { "name": "Bug", "level": 3 },
        { "name": "Sub-Task", "level": 4 }
    ],
    "custom_fields": [
      { "name": "CF Number", "id": "customfield_10125", "type": "number" },
      { "name": "CF Plain Text", "id": "customfield_10124", "type": "text" },
      { "name": "CF Select", "id": "customfield_10126", "type": "select" },
      { "name": "CF Date", "id": "customfield_10123", "type": "date" },
      { "name": "CF Any Value", "id": "customfield_10127", "type": "any" }
    ],
    "priorities": [
      "Highest",
      "High",
      "Medium",
      "Low",
      "Lowest"
    ],
    "project": {
      "key": "PROJECT"
    }
  },
  "metadata": {
    "description": "Complete Jira Importer Toolkit Configuration - Unified Structure",
    "last_updated": "2025-01-27",
    "migration_notes": [
      "This configuration uses a unified structure with single source of truth",
      "All validation rules are now under 'validation.*' section",
      "Issue types and priorities are configured under 'jira.*' section",
      "Legacy 'app.validation.*' paths are no longer supported",
      "Eliminated all duplications for cleaner configuration management",
      "Issue types and priorities are case-sensitive and must match Jira exactly"
    ],
    "version": 8
  },
  "output": {
    "estimate": {
      "unit": "seconds"
    }
  },
  "validation": {
    "estimate": {
      "accept_integers_as": "seconds",
      "fields": [
        "estimate",
        "origest"
      ]
    },
    "fixers": {
      "disabled": [
        "project_key.mismatch",
        "priority.missing",
        "estimate.invalid_format",
        "summary.required"
      ]
    },
    "skip_issuetypes": [
      "comment",
      "note",
      "skip"
    ],
    "skip_rowtype": true
  }
}
