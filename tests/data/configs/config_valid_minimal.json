{
  "app": {
    "logging": {
      "write_to_file": true,
      "console_output": true,
      "log_level": "INFO",
      "max_log_size_mb": 10,
      "max_log_files": 5
    }
  },
    "jira": {
      "validation": {
        "priorities": [
            "higest",
            "hight",
            "medium",
            "low",
            "lowest"
        ],
        "issue_types": [
          "task",
          "bug"
        ]
      }
    }
  }
